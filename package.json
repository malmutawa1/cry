{
  "name": "pressed-laundry",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Pressd — a subscription laundry pickup & delivery app for the Kuwait market (lean/phased model).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:ios": "tsc --noEmit && CAP_BUILD=1 vite build",
    "cap:sync": "npm run build:ios && cap sync ios",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.1",
    "@capacitor/core": "^8.4.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.2",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/splash-screen": "^8.0.2",
    "@capacitor/status-bar": "^8.0.3",
    "@supabase/supabase-js": "^2.110.6",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
